# ── Frontend (.env.local) ─────────────────────────────────────────────────────
# Backend API base URL. Override in .env for staging/production.
VITE_API_BASE_URL="http://localhost:3001/api"

# Analytics (PostHog) — optional, get key at posthog.com
# npm install posthog-js  (then set key to activate)
VITE_POSTHOG_KEY=
VITE_POSTHOG_HOST=https://eu.posthog.com

# Error tracking (Sentry) — optional, get DSN at sentry.io
# npm install @sentry/react  (then set DSN to activate)
VITE_SENTRY_DSN=

# ── Backend (server/.env) ─────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/pero
JWT_SECRET=change_me_in_production_at_least_32_chars
GEMINI_API_KEY=

# Error tracking (backend Sentry)
# npm install @sentry/node  (in /server, then set DSN to activate)
SENTRY_DSN=

# Admin metrics endpoint (curl -H "X-Admin-Secret: ..." /api/admin/metrics)
ADMIN_SECRET=change_me_admin_secret

# Runtime
NODE_ENV=development
PORT=3001
