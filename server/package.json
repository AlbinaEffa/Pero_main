{
  "name": "pero-server",
  "version": "1.0.0",
  "description": "Backend for Pero Writing Studio with PostgreSQL and pgvector",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "maint": "tsx src/scripts/maintenance.ts",
    "maint:status": "tsx src/scripts/maintenance.ts status",
    "maint:costs": "tsx src/scripts/maintenance.ts costs:report",
    "maint:cleanup": "tsx src/scripts/maintenance.ts jobs:cleanup && tsx src/scripts/maintenance.ts embeddings:cleanup",
    "smoke": "node tests/security-smoke.mjs",
    "smoke:ci": "node tests/security-smoke.mjs --no-color",
    "smoke:remote": "SMOKE_ALLOW_REMOTE=true node tests/security-smoke.mjs"
  },
  "dependencies": {
    "@google/genai": "^1.46.0",
    "bcrypt": "^6.0.0",
    "cors": "^2.8.6",
    "docx": "^8.5.0",
    "dotenv": "^16.4.5",
    "drizzle-orm": "^0.30.10",
    "express": "^4.19.2",
    "jsonwebtoken": "^9.0.3",
    "jszip": "^3.10.1",
    "mammoth": "^1.12.0",
    "multer": "^2.1.1",
    "pdf-parse": "^2.4.5",
    "pg": "^8.11.5",
    "xml2js": "^0.6.2"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^2.1.0",
    "@types/node": "^20.12.7",
    "@types/pdf-parse": "^1.1.5",
    "@types/pg": "^8.11.6",
    "@types/supertest": "^7.2.0",
    "@types/xml2js": "^0.4.14",
    "drizzle-kit": "^0.20.17",
    "supertest": "^7.2.2",
    "tsx": "^4.10.4",
    "typescript": "^5.4.5",
    "vitest": "^4.1.0"
  }
}
